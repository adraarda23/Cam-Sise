# Database Configuration
spring.datasource.url=jdbc:postgresql://your-database-host:5432/your-database-name?tcpKeepAlive=true
spring.datasource.username=your-username
spring.datasource.password=your-password
spring.datasource.driver-class-name=org.postgresql.Driver

# JPA/Hibernate Configuration
spring.jpa.database-platform=org.hibernate.dialect.PostgreSQLDialect
spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=true

# Flyway Configuration
spring.flyway.enabled=false

# JWT Configuration
jwt.secret=your-secret-key-minimum-256-bits-for-hs256-algorithm-security
jwt.expiration=86400000

# Gemini API
gemini.api-key=your-gemini-api-key

# Elasticsearch (Audit Logging)
spring.elasticsearch.uris=https://YOUR_CLUSTER_ID.europe-west3.gcp.cloud.es.io:443
spring.elasticsearch.api-key=YOUR_ELASTICSEARCH_API_KEY
